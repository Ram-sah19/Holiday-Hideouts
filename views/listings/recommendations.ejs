<% layout("/layouts/boilerplate") %>
<h3>Recommended for You</h3>

<div class="container">
  <p class="text-muted">Based on your preferences and popular choices</p>
  
  <div class="row row-cols-1 row-cols-sm-1 row-cols-md-2 row-cols-lg-3 g-4">
    <% for(let listing of recommended) { %>
      <a href="/listings/<%= listing._id %>" class="listing-link">
        <div class="card col listing-card">
          <div class="card h-100" style="width: 100%;">
            <img src="<%= listing.image.url %>"
            class="card-img-top" 
            alt="listing_image" style="height:20rem; object-fit: cover;">
            <div class="card-img-overlay"><%= listing.propertyType || 'Property' %></div>
            <div class="card-body">
              <p class="card-text">
                <strong><%= listing.title %></strong><br>
                ₹<%= listing.price.toLocaleString("en-IN") %>/night<br>
                <small><%= listing.location %>, <%= listing.country %></small>
              </p>
            </div>
          </div>
        </div>
      </a>
    <% } %>
  </div>
</div>
